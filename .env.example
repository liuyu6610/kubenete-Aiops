# ================================================================
# KubeSentinel - 环境变量配置模板
# .env.example
#
# 使用方式：
#   cp .env.example .env
#   # 编辑 .env，填入真实的密钥和配置
#   # 注意：.env 文件已加入 .gitignore，请勿提交到代码仓库
# ================================================================

# ── LLM API 配置 ─────────────────────────────────────────────────
# 选择一个 LLM 提供商并填入对应的 API Key

# 通义千问 (阿里云百炼平台)
# 获取地址: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=qwen-turbo
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.1

# DeepSeek (可选，与千问二选一)
# 获取地址: https://platform.deepseek.com/
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_MODEL=deepseek-chat

# OpenAI / 兼容 API (可选)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ── 消息通知 Webhook ──────────────────────────────────────────────
# 飞书机器人 Webhook URL
# 创建方式: 飞书群 → 群设置 → 自定义机器人 → 添加
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 钉钉机器人 Webhook URL (可选)
# DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxxxxxxx

# ── Kubernetes 集群配置 ───────────────────────────────────────────
# K8s API Server 地址（在 n8n Pod 内部使用 service account 时可留空）
K8S_API_SERVER=https://kubernetes.default.svc

# n8n 专用 ServiceAccount Token（由 n8n-rbac.yaml 创建）
# 获取命令: kubectl get secret n8n-healer-token -n monitoring -o jsonpath='{.data.token}' | base64 -d
K8S_TOKEN=eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9.PLACEHOLDER

# K8s CA 证书路径（容器内默认路径，通常不需要修改）
K8S_CA_CERT=/var/run/secrets/kubernetes.io/serviceaccount/ca.crt

# ── n8n 工作流引擎配置 ────────────────────────────────────────────
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_LOG_LEVEL=info

# n8n 基础认证（生产环境建议开启）
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_PLEASE

# n8n Webhook 对外访问地址（Alertmanager 需要能访问到此地址）
# 如使用 NodePort: http://<节点IP>:30567
# 如使用 Ingress: http://n8n.your-domain.com
N8N_WEBHOOK_BASE_URL=http://localhost:30567

# ── Prometheus & Grafana 配置 ────────────────────────────────────
PROMETHEUS_URL=http://kube-prometheus-stack-prometheus.monitoring:9090
ALERTMANAGER_URL=http://kube-prometheus-stack-alertmanager.monitoring:9093
GRAFANA_URL=http://kube-prometheus-stack-grafana.monitoring:80
GRAFANA_ADMIN_PASSWORD=KubeSentinel@2025

# ── 自愈引擎行为配置 ──────────────────────────────────────────────
# LLM 置信度阈值（低于此值需要人工审批）
HEALING_CONFIDENCE_THRESHOLD=0.75

# 高风险操作是否需要人工审批（建议生产环境设为 true）
HIGH_RISK_REQUIRE_APPROVAL=true

# 单次告警最多允许执行几次自动修复（防止无限循环）
MAX_AUTO_HEALING_RETRIES=3

# 告警冷却时间（秒）：同一资源在此时间内不重复触发修复
HEALING_COOLDOWN_SECONDS=300

# ── 日志与审计 ────────────────────────────────────────────────────
# 所有自愈操作的审计日志存储路径（可选，留空则不记录文件日志）
AUDIT_LOG_PATH=/var/log/kubesentinel/audit.log
